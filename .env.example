# Copy to ".env" in the project root (never commit real secrets).
# Values here are overridden by config/{env}.yaml and by exported environment variables.

ENV=dev

# HTTP (optional; defaults in config/dev.yaml)
# HTTP_ADDR=:8080
# HTTP_CORS_ENABLED=true
# HTTP_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# HTTP_RATE_LIMIT_ENABLED=true
# HTTP_RATE_LIMIT_MAX=200
# HTTP_RATE_LIMIT_WINDOW=1m
# HTTP_RATE_LIMIT_REDIS=true
# HTTP_REQUEST_TIMEOUT=60s
# HTTP_BODY_LIMIT=4194304

# i18n (optional; requires locales_dir and JSON files — see README)
# I18N_ENABLED=true
# I18N_DEFAULT_LOCALE=en
# I18N_SUPPORTED_LOCALES=en,tr
# I18N_LOCALES_DIR=locales

# PostgreSQL (GORM / pgx)
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/zatrano?sslmode=disable

# Redis (sessions, cache, rate limit — TLS: use rediss://)
# REDIS_URL=redis://127.0.0.1:6379/0

# JWT (HS256) for /api/v1/private/* — set a long random secret in every environment
# SECURITY_JWT_SECRET=

# Demo POST /api/v1/auth/token (never enable in prod)
# SECURITY_DEMO_TOKEN_ENDPOINT=false

# OAuth2 (browser) — requires Redis; set redirect URIs in provider consoles:
#   {base}/auth/oauth/google/callback  and  {base}/auth/oauth/github/callback
# OAUTH_ENABLED=false
# OAUTH_BASE_URL=http://127.0.0.1:8080
# OAUTH_PROVIDERS_GOOGLE_CLIENT_ID=
# OAUTH_PROVIDERS_GOOGLE_CLIENT_SECRET=
# OAUTH_PROVIDERS_GITHUB_CLIENT_ID=
# OAUTH_PROVIDERS_GITHUB_CLIENT_SECRET=

# Mail (optional; defaults to "log" driver in dev)
# MAIL_DRIVER=smtp
# MAIL_FROM_NAME=ZATRANO
# MAIL_FROM_EMAIL=noreply@example.com
# MAIL_SMTP_HOST=localhost
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USERNAME=
# MAIL_SMTP_PASSWORD=
# MAIL_SMTP_ENCRYPTION=tls
